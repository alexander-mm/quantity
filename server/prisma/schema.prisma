generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreType {
  MAIN_WAREHOUSE
  STORE
}

enum StockOperation {
  IN
  OUT
  NONE
}

enum SyncStatus {
  PENDING
  SYNCED
  ERROR
}

model Role {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  name String @unique

  description String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?

  users User[]
}

model Store {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  code String @unique

  name String

  type StoreType

  address String?

  city String?

  phone String?

  email String?

  manager String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?

  users User[]

  inventoryMovements InventoryMovement[]
}

model User {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  username String @unique

  password String

  firstName String

  lastName String

  email String?

  phone String?

  roleId BigInt

  role Role @relation(fields: [roleId], references: [id])

  storeId BigInt

  store Store @relation(fields: [storeId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?
}

model Category {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  name String @unique

  description String?

  parentCategoryId BigInt?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?

  products Product[]
}

model Brand {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  name String @unique

  description String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?

  products Product[]
}

model UnitOfMeasure {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  code String @unique

  name String @unique

  description String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?

  products Product[]
}

model Product {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  internalCode String @unique

  barcode String @unique

  name String

  description String?

  brandId BigInt

  brand Brand @relation(fields: [brandId], references: [id])

  categoryId BigInt

  category Category @relation(fields: [categoryId], references: [id])

  unitOfMeasureId BigInt

  unitOfMeasure UnitOfMeasure @relation(fields: [unitOfMeasureId], references: [id])

  costPrice Decimal @db.Decimal(12, 2)

  minimumStock Decimal @db.Decimal(12, 2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?

  productPrices ProductPrice[]

  inventoryMovements InventoryMovement[]
}

model MarginProfile {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  name String @unique

  percentage Decimal @db.Decimal(5, 2)

  displayOrder Int

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?

  productPrices ProductPrice[]
}

model ProductPrice {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  productId BigInt

  product Product @relation(fields: [productId], references: [id])

  marginProfileId BigInt

  marginProfile MarginProfile @relation(fields: [marginProfileId], references: [id])

  price Decimal @db.Decimal(12, 2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?

  @@unique([productId, marginProfileId])
}

model Client {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  document String @unique

  firstName String?

  lastName String?

  companyName String?

  phone String?

  email String?

  address String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?
}

model MovementType {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  code String @unique

  name String @unique

  description String?

  affectsStock Boolean @default(true)

  stockOperation StockOperation

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?
}

model InventoryMovement {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  movementTypeId BigInt

  productId BigInt

  product Product @relation(fields: [productId], references: [id])

  storeId BigInt

  store Store @relation(fields: [storeId], references: [id])

  userId BigInt

  clientId BigInt?

  quantity Decimal @db.Decimal(12, 2)

  unitCost Decimal @db.Decimal(12, 2)

  observations String?

  movementDate DateTime

  syncStatus SyncStatus @default(PENDING)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?
}

model InventoryStock {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  productId BigInt

  storeId BigInt

  quantity Decimal @default(0) @db.Decimal(12, 2)

  lastMovementId BigInt?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?

  @@unique([productId, storeId])
}

model Settings {
  id BigInt @id @default(autoincrement())

  uuid String @unique @default(uuid())

  companyName String

  currency String

  syncInterval Int @default(5)

  lowStockAlerts Boolean @default(true)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  createdBy BigInt?

  updatedBy BigInt?
}
